# Local development overrides — DO NOT COMMIT real values
# In production these are set via `fly secrets set`

# Database (Neon production URL or local Postgres)
DATABASE_URL=postgres://kani:kani_dev@localhost:5432/kanicompanion_development

# Rails
RAILS_ENV=development
RAILS_MASTER_KEY=

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173

# Active Record encryption keys (required for token encryption)
# Generate via: bin/rails db:encryption:init
# Then set:
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
